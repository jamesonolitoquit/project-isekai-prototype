# Docker build context exclusions
# Phase 23 Task 2: Production Deployment

# Version control
.git
.gitignore
.gitattributes

# Node dependencies (built in Dockerfile)
node_modules

# Build outputs
coverage
.next
dist
build

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Environment files (secrets should not be in image)
.env.local
.env.*.local

# IDE / Editor files
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Development files
.eslintignore
.prettierignore

# Documentation
README.md
CHANGELOG.md
docs/

# Test files (not needed in production)
jest.config.js
jest.setup.ts
**/*.test.ts
**/*.test.tsx
**/__tests__

# Docker files (not needed in image)
Dockerfile
docker-compose.yml
.dockerignore

# CI/CD
.github
.gitlab-ci.yml
.circleci
