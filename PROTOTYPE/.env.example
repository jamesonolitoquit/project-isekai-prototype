# .env.example - Phase 23 Production Configuration
# Copy to .env.local and fill in with your values
# DO NOT commit .env.local to version control

# Database Configuration
DATABASE_URL=postgresql://isekai:password@localhost:5432/isekai
DB_HOST=localhost
DB_PORT=5432
DB_USER=isekai
DB_PASSWORD=password
DB_NAME=isekai

# Application Configuration
NODE_ENV=production
LOG_LEVEL=info
MAX_PLAYERS=20

# Server Configuration
HTTP_PORT=3000
WEBSOCKET_PORT=8080

# Multiplayer Settings
CONSENSUS_TIMEOUT_MS=3000
MESSAGE_QUEUE_MAX_DEPTH=1000
SNAPSHOT_INTERVAL_TICKS=100

# Security (optional)
JWT_SECRET=your-jwt-secret-here
ALLOW_REMOTE_CONSOLE=false

# Feature Flags
ENABLE_METRICS_DASHBOARD=true
ENABLE_DEV_MODE=false
