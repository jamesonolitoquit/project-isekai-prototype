# ============================================
# PRODUCTION ENVIRONMENT (Railway)
# ============================================

# DATABASE (Railway provides automatically)
DATABASE_URL=postgresql://postgres:xxxxx@containers-us-west-xxx.railway.app:7382/railway

# REDIS (Railway provides automatically)
REDIS_URL=redis://default:xxxxx@containers-us-west-xxx.railway.app:7383

# SECURITY - CHANGE THESE IN PRODUCTION
JWT_SECRET=use-strong-random-secret-in-production-do-not-commit
JWT_EXPIRY=24h

# APPLICATION
NODE_ENV=production
PORT=5000
LOG_LEVEL=info

# FEATURES
BETA_MODE=true
MAX_CONCURRENT_PLAYERS=1000
ENABLE_METRICS=true
METRICS_PORT=9090
