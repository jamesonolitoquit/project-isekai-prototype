# ============================================
# DATABASE
# ============================================
# For local development:
DATABASE_URL=postgresql://isekai:isekai_beta_password@localhost:5432/isekai

# For Railway (auto-provided):
# DATABASE_URL=postgresql://postgres:xxxxx@containers-us-west-xxx.railway.app:7382/railway

# ============================================
# REDIS / CACHE
# ============================================
# For local development:
REDIS_URL=redis://localhost:6379

# For Railway (auto-provided):
# REDIS_URL=redis://default:xxxxx@containers-us-west-xxx.railway.app:7383

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=24h

# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# ============================================
# BETA ACCESS
# ============================================
BETA_MODE=true
MAX_CONCURRENT_PLAYERS=1000

# ============================================
# MONITORING & TELEMETRY
# ============================================
ENABLE_METRICS=true
METRICS_PORT=9090

# Multiplayer Settings
CONSENSUS_TIMEOUT_MS=3000
MESSAGE_QUEUE_MAX_DEPTH=1000
SNAPSHOT_INTERVAL_TICKS=100

# Security (optional)
JWT_SECRET=your-jwt-secret-here
ALLOW_REMOTE_CONSOLE=false

# Feature Flags
ENABLE_METRICS_DASHBOARD=true
ENABLE_DEV_MODE=false
