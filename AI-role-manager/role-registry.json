{
  "version": "1.0",
  "project": "Project Isekai / Luxfier",
  "description": "Role registry for AI Copilot models. Each role defines a specialized behavior profile.",
  "currentPhase": "Prototype",
  "globalContext": [
    "plans/00_MASTER_REFERENCE.md",
    "plans/28_ROADMAP.md"
  ],
  "roles": {
    "router": {
      "file": "router.md",
      "purpose": "Classify incoming tasks and route to the correct specialized role",
      "priority": 0,
      "keywords": ["which role", "help me", "where do I start", "multi-step", "triage"],
      "canDelegateTo": ["coder", "debugger", "planner", "reviewer", "monetizer", "security", "system-thinker"]
    },
    "coder": {
      "file": "roles/engineer.md",
      "purpose": "Engineer: Implement features, write code, AND fix bugs/errors",
      "priority": 1,
      "keywords": ["implement", "write code", "build", "create", "add feature", "component", "function", "API", "endpoint", "bug", "fix", "error", "debug"],
      "contextFiles": [
        "plans/00_MASTER_REFERENCE.md",
        "plans/28_ROADMAP.md",
        "plans/20_ALPHA_DATA_SCHEMA.md",
        "plans/17_SESSION_CONTINUITY.md"
      ],
      "contextNotes": "Supports both /mode:build and /mode:debug. Load specific layer files as needed.",
      "fallback": "system-thinker"
    },
    "debugger": {
      "file": "roles/engineer.md",
      "purpose": "Engineer: Fix bugs, trace errors, AND implement solutions",
      "priority": 1,
      "keywords": ["bug", "error", "fix", "broken", "failing", "crash", "undefined", "null", "stack trace", "test failure", "implement", "code"],
      "contextFiles": [
        "plans/00_MASTER_REFERENCE.md",
        "plans/20_ALPHA_DATA_SCHEMA.md",
        "plans/17_SESSION_CONTINUITY.md",
        "plans/28_ROADMAP.md"
      ],
      "fallback": "coder"
    },
    "engineer": {
      "file": "roles/engineer.md",
      "purpose": "Full Stack Engineer: Unified role for implementation and debugging",
      "priority": 1,
      "keywords": ["engineer", "full stack", "dev", "program", "debug", "test"],
      "contextFiles": [
        "plans/00_MASTER_REFERENCE.md",
        "plans/28_ROADMAP.md"
      ],
      "fallback": "system-thinker"
    },
    "architect": {
      "file": "roles/architect.md",
      "purpose": "Architect: Design systems, manage roadmap, and ensure scalability (includes System Thinker & Monetization)",
      "priority": 1,
      "keywords": ["plan", "architecture", "design", "roadmap", "breakdown", "milestone", "phase", "scope", "specification", "system think", "integration", "scalability", "monetize", "business"],
      "contextFiles": [
        "plans/00_MASTER_REFERENCE.md",
        "plans/28_ROADMAP.md"
      ],
      "contextNotes": "Entry point role. Defines WHAT to build.",
      "fallback": "engineer"
    },
    "qa-specialist": {
      "file": "roles/qa-specialist.md",
      "purpose": "QA Specialist: Code review, security audit, and consistency check (includes Reviewer & Security)",
      "priority": 1,
      "keywords": ["review", "PR", "pull request", "check", "audit", "consistency", "validate", "quality", "security", "auth", "vulnerability", "threat", "compliance"],
      "contextFiles": [
        "plans/00_MASTER_REFERENCE.md",
        "plans/28_ROADMAP.md",
        "plans/20_ALPHA_DATA_SCHEMA.md",
        "plans/18_ANTI_METAGAMING.md"
      ],
      "fallback": "engineer"
    },
    "world-author": {
      "file": "roles/world-author.md",
      "purpose": "Craft world templates, design factions, locations, NPCs, and initial quest lines for simulation",
      "priority": 1,
      "keywords": [
        "world template",
        "json world",
        "faction",
        "location",
        "npc",
        "initial quest",
        "narrative seed",
        "world building"
      ],
      "contextFiles": [
        "plans/PROJECT_OVERVIEW.md",
        "plans/WORLD_TEMPLATE_INSTANCE_MODEL.md",
        "plans/DATA_MODEL.md",
        "BETA/src/engine/worldEngine.ts"
      ],
      "fallback": "planner"
    },

  },
  "classificationRules": {
    "method": "keyword_match_with_intent",
    "priority": "first_match_highest_keyword_density",
    "ambiguousThreshold": "If two roles tie, prefer lower priority number. If still tied, route to router.",
    "multiTaskRule": "If task spans multiple roles, router splits into sub-tasks and assigns each."
  }
}
