{
  "version": "1.0",
  "project": "Project Isekai / Luxfier",
  "description": "Role registry for AI Copilot models. Each role defines a specialized behavior profile.",
  "currentPhase": "Prototype",
  "globalContext": [
    "plans/00_MASTER_REFERENCE.md",
    "plans/28_ROADMAP.md"
  ],
  "roles": {
    "router": {
      "file": "router.md",
      "purpose": "Classify incoming tasks and route to the correct specialized role",
      "priority": 0,
      "keywords": ["which role", "help me", "where do I start", "multi-step", "triage"],
      "canDelegateTo": ["coder", "debugger", "planner", "reviewer", "monetizer", "security", "system-thinker"]
    },
    "coder": {
      "file": "roles/coder.md",
      "purpose": "Implement features, write TypeScript/React code, build engine components",
      "priority": 1,
      "keywords": ["implement", "write code", "build", "create", "add feature", "component", "function", "API", "endpoint"],
      "contextFiles": [
        "plans/00_MASTER_REFERENCE.md",
        "plans/28_ROADMAP.md"
      ],
      "contextNotes": "Load the specific layer file for the task. Never load all plan files at once.",
      "fallback": "system-thinker"
    },
    "debugger": {
      "file": "roles/debugger.md",
      "purpose": "Fix bugs, trace errors, diagnose test failures, resolve runtime issues",
      "priority": 1,
      "keywords": ["bug", "error", "fix", "broken", "failing", "crash", "undefined", "null", "stack trace", "test failure"],
      "contextFiles": [
        "plans/00_MASTER_REFERENCE.md",
        "plans/20_ALPHA_DATA_SCHEMA.md",
        "plans/17_SESSION_CONTINUITY.md"
      ],
      "fallback": "coder"
    },
    "planner": {
      "file": "roles/planner.md",
      "purpose": "Architecture decisions, roadmap management, system design, task breakdown",
      "priority": 1,
      "keywords": ["plan", "architecture", "design", "roadmap", "breakdown", "milestone", "phase", "scope", "specification"],
      "contextFiles": [
        "plans/00_MASTER_REFERENCE.md",
        "plans/28_ROADMAP.md"
      ],
      "contextNotes": "Entry point role. Loads master reference first, drills into layers as needed.",
      "fallback": "system-thinker"
    },
    "reviewer": {
      "file": "roles/reviewer.md",
      "purpose": "Code review, PR validation, consistency checks, cross-reference audits",
      "priority": 1,
      "keywords": ["review", "PR", "pull request", "check", "audit", "consistency", "validate", "quality"],
      "contextFiles": [
        "plans/00_MASTER_REFERENCE.md",
        "plans/28_ROADMAP.md",
        "plans/20_ALPHA_DATA_SCHEMA.md"
      ],
      "fallback": "debugger"
    },
    "monetizer": {
      "file": "roles/monetizer.md",
      "purpose": "Business model, pricing strategy, revenue streams, growth mechanics",
      "priority": 2,
      "keywords": ["monetize", "pricing", "revenue", "business model", "subscription", "freemium", "growth", "market"],
      "contextFiles": [
        "plans/00_MASTER_REFERENCE.md",
        "plans/28_ROADMAP.md",
        "plans/19_ENDGAME_REPLAYABILITY.md"
      ],
      "fallback": "planner"
    },
    "security": {
      "file": "roles/security.md",
      "purpose": "Authentication, authorization, vulnerability assessment, compliance, threat modeling",
      "priority": 2,
      "keywords": ["security", "auth", "vulnerability", "threat", "compliance", "encryption", "permissions", "OWASP"],
      "contextFiles": [
        "plans/00_MASTER_REFERENCE.md",
        "plans/18_ANTI_METAGAMING.md",
        "plans/17_SESSION_CONTINUITY.md",
        "plans/20_ALPHA_DATA_SCHEMA.md"
      ],
      "fallback": "reviewer"
    },
    "system-thinker": {
      "file": "roles/system-thinker.md",
      "purpose": "Cross-cutting concerns, system integration, scalability, dependency analysis",
      "priority": 2,
      "keywords": ["integration", "scalability", "trade-off", "dependency", "cross-cutting", "performance", "infrastructure"],
      "contextFiles": [
        "plans/00_MASTER_REFERENCE.md",
        "plans/28_ROADMAP.md",
        "plans/20_ALPHA_DATA_SCHEMA.md"
      ],
      "fallback": "planner"
    }
  },
  "classificationRules": {
    "method": "keyword_match_with_intent",
    "priority": "first_match_highest_keyword_density",
    "ambiguousThreshold": "If two roles tie, prefer lower priority number. If still tied, route to router.",
    "multiTaskRule": "If task spans multiple roles, router splits into sub-tasks and assigns each."
  }
}
